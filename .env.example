# Public — safe to ship to the browser bundle (RLS-gated anon key)
NEXT_PUBLIC_SUPABASE_URL=https://gbwusopifbyhlcppbfnl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only — NEVER prefix with NEXT_PUBLIC_. Bypasses RLS. Used only in
# app/api/register/route.js, app/api/register/sign/route.js, and
# app/api/keepalive/route.js.
SUPABASE_SERVICE_ROLE_KEY=

# There is no email/SMS config here on purpose. NO OUTBOUND COMMS is a hard
# constraint (JD ruling, 2026-07-21) — this is a test site. Registrations
# save and generate a signed PDF locally; nothing is ever sent externally.
# "Who gets notified of what" is a future admin-panel feature, not built yet.
